---
import { articleSchema } from "../../../content/config";
import SpecHeader from "../../SpecHeader.astro";
import SpecLineItem from "../../SpecLineItem.astro";

interface Props {
  isolatedComponentId?: string;
}
const { isolatedComponentId } = Astro.props;
---

{(!isolatedComponentId || isolatedComponentId === "spec-header") && (
<div class="ds-component-block" id="spec-header">
  <SpecLineItem 
    title="Spec Header" 
    url={isolatedComponentId ? "/resources/design-system/components" : "/resources/design-system/components/spec-header"} 
    tags={[isolatedComponentId ? "View All" : "Isolate"]} 
    headingLevel="h3" 
  />
  <p>Standardized header for specification pages (Concepts, Patterns, Practices). Supports data-driven metadata rendering.</p>

  <div style="margin-bottom: 1rem;">
    <SpecHeader
      data={articleSchema.parse(
        {
          title: "Example Specification",
          description: "A standardized header component for specification pages.",
          status: "Live",
          lastUpdated: new Date(),
          tags: ["example", "demo"],
        }
      )}
    />
  </div>

  <pre><code>{`<SpecHeader
  data={articleSchema.parse({
    title: "Example Specification",
    description: "A standardized header component...",
    status: "Live",
    lastUpdated: new Date(),
    tags: ["example"]
  })}
/>`}</code></pre>
</div>
)}
