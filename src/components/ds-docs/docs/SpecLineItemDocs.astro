---
import SpecLineItem from "../../SpecLineItem.astro";
import DsComponentHeader from "../DsComponentHeader.astro";

interface Props {
  isolatedComponentId?: string;
}
const { isolatedComponentId } = Astro.props;
---

{(!isolatedComponentId || isolatedComponentId === "spec-line-item") && (
<div class="ds-component-block" id="spec-line-item">
  <DsComponentHeader
    title="Spec Line Item"
    url={isolatedComponentId ? "/resources/design-system/components" : "/resources/design-system/components/spec-line-item"}
    isIsolated={!!isolatedComponentId}
  />
  <p>Dense, horizontal row component for displaying long directory lists of concept or pattern items. Designed to scale better vertically than standard grid cards.</p>

  <p>Each row renders as a single semantic <code>&lt;a&gt;</code> tag containing the title, an optional status badge, tags, and meta text (usually a date). The component stacks without spacing conflicts in flex or grid containers.</p>

  <ul>
    <li><strong>Root element:</strong> Semantic <code>&lt;a&gt;</code> tag — the entire row is clickable.</li>
    <li><strong>Context:</strong> Must be placed inside a <code>&lt;li&gt;</code> within a <code>&lt;ul&gt;</code> for correct list semantics.</li>
    <li><strong>Status badge:</strong> Optional <code>StatusBadge</code> rendered inline with the title.</li>
    <li><strong>Meta &amp; tags:</strong> Right-aligned, monospace-styled secondary information.</li>
  </ul>


  <div class="example-container">
    <div class="example">
      <h4 class="text-heading-3">Example</h4>
      <p>This is the listing of patterns, that are live!</p>
      <ul class="spec-line-list">
        <li>
          <SpecLineItem
            title="Living Specs"
            url="/practices/living-specs"
            meta="Dec 22, 2025"
            status="Experimental"
            tags={["documentation", "spec-driven-development"]}
          />
        </li>
        <li>
          <SpecLineItem
            title="Context Engineering"
            url="/concepts/context-engineering"
            meta="Oct 12, 2026"
            status="Live"
          />
        </li>
        <li>
          <SpecLineItem
            title="Micro-Commits"
            url="/practices/micro-commits"
            meta="Jan 5, 2026"
            status="Live"
            tags={["workflow"]}
          />
        </li>
      </ul>
    </div>
  </div>

  <pre><code>{`<ul class="spec-line-list">
  <li>
    <SpecLineItem
      title="Living Specs"
      url="/practices/living-specs"
      meta="Dec 22, 2025"
      status="Experimental"
      tags={["documentation", "spec-driven-development"]}
    />
  </li>
</ul>`}</code></pre>
</div>
)}
