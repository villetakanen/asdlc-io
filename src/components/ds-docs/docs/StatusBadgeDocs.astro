---
import SpecLineItem from "../../SpecLineItem.astro";
import StatusBadge from "../../StatusBadge.astro";

interface Props {
  isolatedComponentId?: string;
}
const { isolatedComponentId } = Astro.props;
---

{(!isolatedComponentId || isolatedComponentId === "status-badge") && (
<div class="ds-component-block" id="status-badge">
  <SpecLineItem 
    title="Status Badge" 
    url={isolatedComponentId ? "/resources/design-system/components" : "/resources/design-system/components/status-badge"} 
    tags={[isolatedComponentId ? "View All" : "Isolate"]} 
    headingLevel="h3" 
  />
  <p>Monospace badges for status indicators:</p>
  <div class="border-box" style="margin-bottom: 1rem; display: flex; gap: 1rem; flex-wrap: wrap;">
    <StatusBadge status="Draft" />
    <StatusBadge status="Proposed" />
    <StatusBadge status="Live" />
    <StatusBadge status="Deprecated" />
    <StatusBadge status="Experimental" />
  </div>
  <pre><code>&lt;StatusBadge status="Live" /&gt;</code></pre>
</div>
)}
