---
import StatusBadge from "./StatusBadge.astro";

interface Props {
  title: string;
  url: string;
  meta?: string;
  status?: string;
  tags?: string[];
  headingLevel?: "h2" | "h3" | "h4" | "h5" | "h6";
}

const { title, url, meta, status, tags, headingLevel = "h3" } = Astro.props;
const TitleTag = headingLevel;
---

<a href={url} class="spec-line-item">
  <div class="spec-line-item__content">
    <div class="spec-line-item__title-group">
      <TitleTag class="spec-line-item__title">{title}</TitleTag>
      {status && <StatusBadge status={status} />}
    </div>
    
    <div class="spec-line-item__meta-group">
      {tags && tags.length > 0 && (
        <div class="spec-line-item__tags">
          {tags.map((tag) => (
            <span class="spec-line-item__tag mono">{tag}</span>
          ))}
        </div>
      )}
      {meta && <span class="spec-line-item__meta mono">{meta}</span>}
    </div>
  </div>
</a>

<style>
  .spec-line-item {
    display: block;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--c-border);
    padding: 1rem var(--s-gap);
    transition: background-color 0.2s ease;
  }

  .spec-line-item:hover,
  .spec-line-item:focus-visible {
    background-color: var(--c-bg-surface);
  }

  .spec-line-item__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-gap);
  }

  .spec-line-item__title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .spec-line-item__title {
    margin: 0;
    font-size: 1.125rem;
  }

  .spec-line-item__meta-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .spec-line-item__tags {
    display: flex;
    gap: 0.5rem;
  }

  .spec-line-item__tag,
  .spec-line-item__meta {
    font-size: 0.8125rem;
    color: var(--c-text-secondary);
  }

  .spec-line-item:hover .spec-line-item__tag,
  .spec-line-item:hover .spec-line-item__meta {
    color: inherit;
  }
</style>
