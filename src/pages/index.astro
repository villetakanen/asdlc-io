---
import { Content as AccessKnowledgeBase } from "../components/definitions/access-knowledge-base.md";
import { Content as AgenticFactory } from "../components/definitions/homepage-agentic-factory.md";
import { Content as KnowledgeBase } from "../components/definitions/homepage-knowledge-base.md";
import { Content as ManifestoIntro } from "../components/definitions/homepage-manifesto-intro.md";
import { Content as QuickStart } from "../components/definitions/homepage-quick-start.md";
import { Content as TwoNarratives } from "../components/definitions/homepage-two-narratives.md";
import StructuredData from "../components/StructuredData.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const siteURL = Astro.site?.toString() ?? "https://asdlc.io/";
const siteDescription =
  "The playbook for industrializing software engineering. Patterns, practices, and standards for building the software factory.";
---

<StructuredData type="Organization" data={{
  name: "ASDLC.io",
  url: siteURL,
  logo: `${siteURL}asdlc.svg`,
  description: siteDescription,
}} />

<StructuredData type="WebSite" data={{
  name: "ASDLC.io",
  url: siteURL,
  description: siteDescription,
}} />

<BaseLayout
  title="ASDLC.io | The Agentic Software Development Life Cycle Framework"
  description={siteDescription}
>
  <article class="prose">
    <section>
      <ManifestoIntro />
    </section>

    <div class="full border-t border-b my-1 py-1">
      <section class="breakout">
        <AccessKnowledgeBase />
      </section>
    </div>

    <section>
      <TwoNarratives />
    </section>

    <section>
      <AgenticFactory />
    </section>

    <section>
      <KnowledgeBase />
    </section>

    <section class="border-box" style="margin-top: 2rem; background: #f9f9f9;">
      <QuickStart />
    </section>
  </article>
</BaseLayout>
