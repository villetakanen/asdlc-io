# Google Search Console integration (see specs/gsc-integration/spec.md)

# The GSC property to snapshot. Domain properties use the sc-domain: prefix.
GSC_SITE_URL=sc-domain:asdlc.io

# GCP project billed for API quota (sent as the x-goog-user-project header).
# Optional — falls back to `gcloud config get-value project`.
GSC_QUOTA_PROJECT=your-gcp-project-id

# Auth note: `pnpm gsc:snapshot` uses Application Default Credentials via the
# gcloud CLI (the property owner's own login), not a service-account key:
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/webmasters.readonly
# The spec's GSC_SERVICE_ACCOUNT_KEY path is not currently wired.
